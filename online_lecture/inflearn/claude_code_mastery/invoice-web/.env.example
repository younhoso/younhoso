# ──────────────────────────────────────────────────────────────
# 노션 견적서 공유 서비스 환경변수 템플릿
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요:
#   cp .env.example .env.local
# ──────────────────────────────────────────────────────────────

# 노션 API 키 (서버 사이드 전용 — NEXT_PUBLIC_ 접두사 없음)
# 노션 통합(Integration) 생성: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxx

# 공급자(나) 정보 — 견적서 헤더에 표시
# NEXT_PUBLIC_ 접두사로 클라이언트에서도 읽을 수 있음
NEXT_PUBLIC_SUPPLIER_NAME=홍길동
NEXT_PUBLIC_SUPPLIER_EMAIL=contact@example.com
